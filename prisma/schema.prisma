generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  password        String
  role            UserRole   @default(STAFF)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       AuditLog[]
  ordersConfirmed Order[]    @relation("ConfirmedByUser")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Customer {
  id                   String           @id @default(cuid())
  name                 String
  email                String           @unique
  phone                String?
  idDoc                String?
  address              String?
  password             String?
  isEmailVerified      Boolean          @default(false)
  phoneVerified        Boolean          @default(false)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  isBlocked            Boolean          @default(false)
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  customerActions      CustomerAction[]
  orders               Order[]
  otpTokens            OTPToken[]
  reviews              Review[]

  @@index([email])
  @@index([isBlocked])
  @@index([isEmailVerified])
  @@map("customers")
}

model OTPToken {
  id         String   @id @default(cuid())
  customerId String
  phone      String
  pinHash    String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([phone])
  @@map("otp_tokens")
}

model CustomerAction {
  id          String             @id @default(cuid())
  customerId  String
  action      CustomerActionType
  description String?
  ip          String?
  userAgent   String?
  createdAt   DateTime           @default(now())
  customer    Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
  @@map("customer_actions")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Supplier {
  id              String    @id @default(cuid())
  name            String
  rif             String?   @unique
  contactName     String?
  phone           String?
  email           String?
  address         String?
  commercialTerms String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]

  @@index([rif])
  @@index([isActive])
  @@map("suppliers")
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  description        String
  price              Float
  promoPrice         Float?
  sku                String              @unique
  isActive           Boolean             @default(true)
  isFeatured         Boolean             @default(false)
  isBestSeller       Boolean             @default(false)
  isMostSearched     Boolean             @default(false)
  isNew              Boolean             @default(false)
  stock              Int                 @default(0)
  lowStockThreshold  Int                 @default(5)
  averageRating      Float               @default(0)
  totalReviews       Int                 @default(0)
  metaTitle          String?
  metaDescription    String?
  type               ProductType         @default(PRODUCT)
  time               Int?                @default(0)
  categoryId         String
  supplierId         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  orderItems         OrderItem[]
  images             ProductImage[]
  prompts            ProductPrompt[]
  variants           ProductVariant[]
  category           Category            @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  reviews            Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@index([isNew])
  @@index([stock])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  value      String
  sku        String      @unique
  price      Float?
  stock      Int         @default(0)
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model ProductPrompt {
  id        String   @id @default(cuid())
  productId String
  version   Int      @default(1)
  prompt    String
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
  @@map("product_prompts")
}

model Order {
  id              String               @id @default(cuid())
  orderNumber     String               @unique
  customerId      String?
  customerName    String
  customerEmail   String
  customerPhone   String
  bankName        String
  accountHolder   String
  referenceNumber String
  transferAmount  Float
  transferDate    DateTime
  voucherUrl      String?
  subtotal        Float
  total           Float
  status          OrderStatus          @default(PENDIENTE)
  internalNotes   String?
  confirmedById   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  auditLogs       AuditLog[]
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  confirmedBy     User?                @relation("ConfirmedByUser", fields: [confirmedById], references: [id])
  customer        Customer?            @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  sku       String
  price     Float
  quantity  Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model InventoryMovement {
  id          String                @id @default(cuid())
  productId   String
  type        InventoryMovementType
  quantity    Int
  stockBefore Int
  stockAfter  Int
  reason      String?
  reference   String?
  createdAt   DateTime              @default(now())
  product     Product               @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Review {
  id            String       @id @default(cuid())
  productId     String
  customerId    String?
  reviewerName  String
  rating        Int
  comment       String
  adminResponse String?
  status        ReviewStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  customer      Customer?    @relation(fields: [customerId], references: [id])
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

model SiteConfig {
  id                          Int      @id @default(1)
  appName                     String   @default("Ecommerce Premium")
  metadataTitle               String   @default("Ecommerce NoDoz")
  metadataDescription         String   @default("Ecommerce Premium")
  logoUrl                     String   @default("")
  faviconUrl                  String   @default("")
  defaultTheme                String   @default("system")
  googleAnalyticsId           String   @default("")
  metaOgImageUrl              String   @default("")
  colorBgPrimary              String   @default("#FFFFFF")
  colorBgSecondary            String   @default("#F8FAFC")
  colorTextPrimary            String   @default("#0F172A")
  colorTextSecondary          String   @default("#475569")
  colorAccentPrimary          String   @default("#111827")
  colorAccentSecondary        String   @default("#6366F1")
  colorButtonPrimary          String   @default("#111827")
  colorBorder                 String   @default("#E2E8F0")
  heroRotationIntervalMs      Int      @default(5000)
  heroMaxProducts             Int      @default(5)
  heroShowProductCard         Boolean  @default(true)
  heroShowUrgencyBar          Boolean  @default(true)
  heroCtaPrimaryLabel         String   @default("Ver producto")
  heroCtaSecondaryLabel       String   @default("Ver catálogo")
  heroSubtitle                String   @default("")
  featuredBestSellersTitle    String   @default("Más Vendidos")
  featuredBestSellersSubtitle String   @default("Lo que nuestros clientes eligen")
  featuredBestSellersLimit    Int      @default(8)
  featuredNewArrivalsTitle    String   @default("Novedades")
  featuredNewArrivalsLimit    Int      @default(8)
  featuredTrendingTitle       String   @default("Tendencias")
  featuredTrendingLimit       Int      @default(8)
  featuredShowViewAllLink     Boolean  @default(true)
  catalogTitle                String   @default("Nuestro Catálogo")
  catalogSubtitle             String   @default("Encuentra exactamente lo que buscas...")
  catalogPageSize             Int      @default(24)
  catalogDefaultSort          String   @default("newest")
  catalogShowFilters          Boolean  @default(true)
  catalogShowPagination       Boolean  @default(true)
  socialProofCustomerLabel    String   @default("Clientes")
  socialProofProductLabel     String   @default("Productos")
  socialProofThirdStatLabel   String   @default("Seguro")
  socialProofThirdStatValue   String   @default("100%")
  socialProofBgColor          String   @default("#2563EB")
  trustBadge1Title            String   @default("Pago seguro")
  trustBadge1Description      String   @default("Transferencia bancaria protegida")
  trustBadge2Title            String   @default("Verificación manual")
  trustBadge2Description      String   @default("Validamos cada comprobante")
  trustBadge3Title            String   @default("Soporte por WhatsApp")
  trustBadge3Description      String   @default("Atención personalizada inmediata")
  trustBadge4Title            String   @default("Productos garantizados")
  trustBadge4Description      String   @default("Calidad premium asegurada")
  whatsappNumber              String   @default("")
  whatsappMessage             String   @default("¡Hola! Necesito ayuda con una compra.")
  whatsappFabPosition         String   @default("bottom-right")
  ctaBannerTitle              String   @default("Crea tu cuenta y mejora tu experiencia")
  ctaBannerDescription        String   @default("Lleva un historial de todos tus pedidos...")
  ctaBannerPrimaryLabel       String   @default("Registrarme")
  ctaBannerSecondaryLabel     String   @default("Ya tengo cuenta")
  showFooter                  Boolean  @default(true)
  footerCopyright             String   @default("© 2025 Ecommerce Premium")
  footerShowSocialLinks       Boolean  @default(false)
  footerInstagramUrl          String   @default("")
  footerFacebookUrl           String   @default("")
  footerTiktokUrl             String   @default("")
  showHeroBanner              Boolean  @default(true)
  showCategoryBar             Boolean  @default(true)
  showSocialProofBanner       Boolean  @default(true)
  showFeaturedBestSellers     Boolean  @default(true)
  showFeaturedNewArrivals     Boolean  @default(true)
  showCustomerCTABanner       Boolean  @default(true)
  showFeaturedTrending        Boolean  @default(true)
  showCatalogSection          Boolean  @default(true)
  showTrustBadges             Boolean  @default(true)
  showWhatsAppFAB             Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("site_config")
}

model AuditLog {
  id            String   @id @default(cuid())
  entity        String
  entityId      String
  action        String
  changes       Json
  performedById String?
  ip            String?
  orderId       String?
  createdAt     DateTime @default(now())
  order         Order?   @relation(fields: [orderId], references: [id])
  performedBy   User?    @relation(fields: [performedById], references: [id])

  @@index([entity, entityId])
  @@index([performedById])
  @@index([createdAt])
  @@map("audit_logs")
}

model BusinessProfile {
  id        Int      @id @default(1)
  fullName  String   @default("")
  tagline   String?
  avatarUrl String?
  bio       String?
  resumeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_profile")
}

model ProfileSection {
  id          String         @id @default(cuid())
  title       String
  subtitle    String?
  slug        String         @unique
  icon        String?
  order       Int            @default(0)
  isVisible   Boolean        @default(true)
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  fields      ProfileField[]

  @@index([isPublished, isVisible, order])
  @@map("profile_sections")
}

model ProfileField {
  id        String           @id @default(cuid())
  sectionId String
  fieldKey  String
  label     String
  fieldType ProfileFieldType @default(TEXT)
  value     String           @default("")
  order     Int              @default(0)
  isVisible Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  section   ProfileSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, isVisible, order])
  @@map("profile_fields")
}

enum ProfileFieldType {
  TEXT
  HTML
  IMAGE_URL
  LINK
  DATE
  NUMBER
}

enum UserRole {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDIENTE
  VERIFICANDO
  CONFIRMADA
  EN_PROCESO
  COMPLETADA
  CANCELADA
  RECHAZADA
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InventoryMovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

enum CustomerActionType {
  LOGIN
  LOGOUT
  REGISTER
  UPDATE_PROFILE
  CHANGE_PASSWORD
  DELETE_ACCOUNT_REQUEST
  VIEWED_ORDER
}

enum ProductType {
  PRODUCT
  SERVICE
}
